# More info: https://docs.docker.com/engine/reference/builder/#dockerignore-file
# Ignore everything by default and re-include only needed files
**

# Re-include Go source files (but not *_test.go)
!**/*.go
**/*_test.go

# Re-include Go module files
!go.mod
!go.sum

# Re-include the vendor tree (generated by `make docker-build` before docker
# build; required during development because the host `replace ... => ../beyla` directive points
# outside the Docker build context).
!vendor/**
